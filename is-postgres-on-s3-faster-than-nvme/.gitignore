# Terraform / OpenTofu — keep .terraform.lock.hcl committed for reproducibility
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfstate.*.backup
terraform/*.tfvars
terraform/persistent/.terraform/
terraform/persistent/terraform.tfstate
terraform/persistent/terraform.tfstate.backup
terraform/persistent/terraform.tfstate.*.backup
terraform/persistent/*.tfvars
terraform/analysis/.terraform/
terraform/analysis/terraform.tfstate
terraform/analysis/terraform.tfstate.backup
terraform/analysis/terraform.tfstate.*.backup
terraform/analysis/*.tfvars
# ami.auto.tfvars is operator-generated by `make bake`; each operator
# bakes their own AMI in their own AWS account.
terraform/ami.auto.tfvars
terraform/.terraform.tfstate.lock.info
terraform/crash.log
terraform/crash.*.log

# Ansible
ansible/*.retry
ansible/.vault-password
ansible/inventory.json

# Python / uv
analysis/.venv/
analysis/__pycache__/
analysis/**/__pycache__/
analysis/*.egg-info/
analysis/.python-version

# Results — only committed sample sets live in results/ ; everything else is local
results/local/
results/smoke/
results/scratch/
results/campaign-*/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
