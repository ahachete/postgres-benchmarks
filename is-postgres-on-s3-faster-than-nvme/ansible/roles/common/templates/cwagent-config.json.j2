{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "metrics": {
    "namespace": "PgBench",
    "metrics_collected": {
      "cpu": {
        "measurement": ["usage_idle", "usage_iowait", "usage_user", "usage_system"],
        "totalcpu": true,
        "metrics_collection_interval": 60
      },
      "mem": {
        "measurement": ["used_percent", "available_percent"],
        "metrics_collection_interval": 60
      },
      "swap": {
        "measurement": ["used_percent"],
        "metrics_collection_interval": 60
      },
      "disk": {
        "measurement": ["used_percent", "free"],
        "metrics_collection_interval": 60,
        "resources": ["/", "/mnt/pgdata"],
        "ignore_file_system_types": ["sysfs", "devtmpfs", "tmpfs", "proc", "cgroup"]
      },
      "diskio": {
        "measurement": ["reads", "writes", "read_bytes", "write_bytes", "io_time", "iops_in_progress"],
        "metrics_collection_interval": 60,
        "resources": ["nvme0n1", "nvme1n1", "nbd0", "md0"]
      },
      "netstat": {
        "measurement": ["tcp_established", "tcp_time_wait"],
        "metrics_collection_interval": 60
      }
    },
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "InstanceType": "${aws:InstanceType}"
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/mnt/pgdata/main/log/postgresql-*.log",
            "log_group_name": "/pgbench/postgres",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 7,
            "timezone": "UTC"
          },
          {
            "file_path": "/opt/bench/runs/*/*/*/run.log",
            "log_group_name": "/pgbench/runlog",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 7,
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
