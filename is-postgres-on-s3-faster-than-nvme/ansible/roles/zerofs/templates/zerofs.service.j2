[Unit]
Description=ZeroFS S3-backed NBD server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={{ zerofs_bin }} run --config /etc/zerofs.toml
Restart=on-failure
RestartSec=5
User=root
Group=root
Environment=AWS_DEFAULT_REGION={{ aws_region }}
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
