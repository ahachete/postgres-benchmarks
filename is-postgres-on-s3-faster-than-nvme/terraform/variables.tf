variable "region" {
  description = "AWS region. us-east-2 (Ohio) is the default — fewer notorious incidents than us-east-1, S3 gateway endpoint = $0 in-region traffic."
  type        = string
  default     = "us-east-2"
}

variable "scenario" {
  description = "Storage scenario: nvme-ext4, nvme-zfs, nvme-zfs-fpi, nvme-zfs-rec32k, nvme-zfs-rec128k."
  type        = string
  default     = "nvme-ext4"

  validation {
    condition = contains([
      "nvme-ext4", "nvme-zfs", "nvme-zfs-fpi", "nvme-zfs-rec32k", "nvme-zfs-rec128k",
    ], var.scenario)
    error_message = "scenario must be one of: nvme-ext4, nvme-zfs, nvme-zfs-fpi, nvme-zfs-rec{32,128}k."
  }
}

variable "cluster" {
  description = "If true, provision a 3-node sync-replication cluster across 3 AZs (Phase 2)."
  type        = bool
  default     = false
}

variable "instance_type" {
  description = "EC2 instance type. Must have local NVMe instance store."
  type        = string
  default     = "i7i.4xlarge"
}

variable "use_spot" {
  description = "If true (default), request spot instances. Set false to fall back to on-demand — typically needed when 3-node cluster runs hit MaxSpotInstanceCountExceeded against a low account spot vCPU quota."
  type        = bool
  default     = true
}

variable "base_ami_id" {
  description = "Base AMI to launch from. Empty string (default) means use the latest Canonical Ubuntu 24.04 amd64 AMI; set to an `ami-…` to use a baked image (typically generated by `make bake` and written to ami.auto.tfvars)."
  type        = string
  default     = ""
}

variable "keep_bucket" {
  description = "If true, keep the S3 bench bucket on terraform destroy (skips force_destroy + lifecycle delete). Useful when archiving result artifacts."
  type        = bool
  default     = false
}

variable "budget_limit_usd" {
  description = "Monthly AWS Budgets cost cap, in USD, scoped to this project's resources via tags. 0 disables the budget."
  type        = number
  default     = 30
}

variable "budget_alert_email" {
  description = "Optional email to notify when 80%/100% of the budget is reached. Empty string disables notifications (the budget itself still tracks)."
  type        = string
  default     = ""
}
